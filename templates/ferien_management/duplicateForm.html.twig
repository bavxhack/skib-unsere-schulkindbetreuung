<div class="modal-header">
    <h5 class="modal-title">{% trans %}Ferienprogramm duplizieren{% endtrans %}</h5>
    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
        <span aria-hidden="true">&times;</span>
    </button>
</div>
<div class="modal-body">
    <form method="post" action="{{ path('ferien_management_duplicate', {'ferien_id': block.id, 'org_id': org.id}) }}">
        <div class="form-group">
            <label for="duplicate_start_date">{% trans %}Startdatum{% endtrans %}</label>
            <input id="duplicate_start_date" name="start_date" type="date" class="form-control" required>
        </div>
        <div class="form-group">
            <label for="duplicate_end_date">{% trans %}Enddatum{% endtrans %}</label>
            <input id="duplicate_end_date" name="end_date" type="date" class="form-control" required>
        </div>
        <button type="submit" class="btn btn-primary">{% trans %}Kopien erstellen{% endtrans %}</button>
    </form>
</div>
