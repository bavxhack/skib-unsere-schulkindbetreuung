{% extends 'adminBase.html.twig' %}
{% import "form/macros.html.twig" as a2lixTranslations %}

{% block content %}
    <section class="city-config-page py-4">
        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-12 col-xxl-11">
                    <div class="config-shell card border-0 shadow-sm">
                        <div class="config-header card-body border-bottom">
                            <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
                                <div>
                                    <div class="config-eyebrow">Verwaltung</div>
                                    <h1 class="config-title mb-1">{{ title }}</h1>
                                    <p class="config-subtitle mb-0">
                                        Pflege hier alle Einstellungen, Texte, Module und E-Mail-Vorlagen für die Stadt.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="card-body p-0">
                            {% if errors|length > 0 %}
                                <div class="alert alert-danger rounded-0 border-0 border-bottom mb-0 px-4 py-3">
                                    <div class="fw-bold mb-2">Bitte korrigiere folgende Fehler:</div>
                                    <ul class="mb-0 ps-3">
                                        {% for error in errors %}
                                            <li>{{ error.message }}</li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            {% endif %}

                            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'city-config-form'}}) }}

                            <div class="row g-0">
                                <div class="col-xl-3 border-end config-sidebar-wrap">
                                    <div class="config-sidebar sticky-top">
                                        <div class="sidebar-inner p-3 p-lg-4">
                                            <div class="sidebar-title">Bereiche</div>
                                            <div class="nav flex-column nav-pills config-nav" id="city-config-tabs" role="tablist" aria-orientation="vertical">
                                                <a class="nav-link active" id="tab-allgemein-link" data-toggle="tab" href="#allgemein" role="tab" aria-controls="allgemein" aria-selected="true">
                                                    <span>Allgemein</span>
                                                    <small>Basisdaten</small>
                                                </a>
                                                <a class="nav-link" id="tab-bilder-link" data-toggle="tab" href="#bilder" role="tab" aria-controls="bilder" aria-selected="false">
                                                    <span>Aussehen</span>
                                                    <small>Farben, Logos, Medien</small>
                                                </a>
                                                <a class="nav-link" id="tab-module-link" data-toggle="tab" href="#module" role="tab" aria-controls="module" aria-selected="false">
                                                    <span>Module</span>
                                                    <small>Funktionen aktivieren</small>
                                                </a>
                                                <a class="nav-link" id="tab-texte-link" data-toggle="tab" href="#texte" role="tab" aria-controls="texte" aria-selected="false">
                                                    <span>Texte</span>
                                                    <small>Allgemeine Inhalte</small>
                                                </a>
                                                <a class="nav-link" id="tab-rechtliches-link" data-toggle="tab" href="#rechtliches" role="tab" aria-controls="rechtliches" aria-selected="false">
                                                    <span>Rechtliches</span>
                                                    <small>Impressum & Datenschutz</small>
                                                </a>
                                                <a class="nav-link" id="tab-schulkindbetreuung-link" data-toggle="tab" href="#schulkindbetreuung" role="tab" aria-controls="schulkindbetreuung" aria-selected="false">
                                                    <span>Schulkindbetreuung</span>
                                                    <small>Regeln & Sonderfälle</small>
                                                </a>
                                                <a class="nav-link" id="tab-ferienbetreeuung-link" data-toggle="tab" href="#ferienbetreeuung" role="tab" aria-controls="ferienbetreeuung" aria-selected="false">
                                                    <span>Ferienbetreuung</span>
                                                    <small>Erweiterbar</small>
                                                </a>
                                                <a class="nav-link" id="tab-emails-link" data-toggle="tab" href="#emails" role="tab" aria-controls="emails" aria-selected="false">
                                                    <span>E-Mails</span>
                                                    <small>Templates & Variablen</small>
                                                </a>
                                                <a class="nav-link" id="tab-auto-assign" data-toggle="tab" href="#auto-assign" role="tab" aria-controls="auto-assign" aria-selected="false">
                                                    <span>Automatische Blockzuweisung</span>
                                                    <small>Gewichtungsformel</small>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-xl-9">
                                    <div class="config-content">
                                        <div class="config-toolbar d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3 mb-4">
                                            <div>
                                                <div class="toolbar-title">Stadt-Konfiguration</div>
                                                <div class="toolbar-subtitle">Alle Einstellungen an einem Ort, klar gruppiert und deutlich lesbarer.</div>
                                            </div>
                                            <div class="d-flex gap-2">
                                                {{ form_row(form.submit, {'attr': {'class': 'btn btn-primary px-4 mb-0'}}) }}
                                            </div>
                                        </div>

                                        <div class="tab-content" id="city-config-tab-content">
                                            <div class="tab-pane fade show active" id="allgemein" role="tabpanel" aria-labelledby="tab-allgemein-link">
                                                <div class="section-head">
                                                    <h2>Allgemein</h2>
                                                    <p>Basisinformationen und zentrale Kontaktdaten der Stadt.</p>
                                                </div>
                                                <div class="config-card">
                                                    <div class="row g-4">
                                                        {% if form.slug is defined %}
                                                            <div class="col-lg-6">{{ form_row(form.slug) }}</div>
                                                        {% endif %}
                                                        <div class="col-lg-6">{{ form_row(form.name) }}</div>
                                                        <div class="col-lg-6">{{ form_row(form.email) }}</div>
                                                        <div class="col-lg-6">{{ form_row(form.telefon) }}</div>
                                                        <div class="col-lg-6">{{ form_row(form.adresse) }}</div>
                                                        <div class="col-lg-6">{{ form_row(form.adresszusatz) }}</div>
                                                        <div class="col-md-4">{{ form_row(form.plz) }}</div>
                                                        <div class="col-md-8">{{ form_row(form.ort) }}</div>
                                                        <div class="col-lg-6">{{ form_row(form.ansprechpartner) }}</div>
                                                        <div class="col-lg-6">{{ form_row(form.stadtHomepage) }}</div>
                                                        <div class="col-12">{{ a2lixTranslations.partialTranslations(form.translations, ['coverText']) }}</div>
                                                        <div class="col-lg-6">{{ form_row(form.emailDokumente_rechnung) }}</div>
                                                        <div class="col-lg-6">{{ form_row(form.emailDokumente_confirm) }}</div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="tab-pane fade" id="bilder" role="tabpanel" aria-labelledby="tab-bilder-link">
                                                <div class="section-head">
                                                    <h2>Aussehen</h2>
                                                    <p>Lege Bildsprache, Farben und Logos für den Auftritt fest.</p>
                                                </div>
                                                <div class="config-card">
                                                    <div class="row g-4">
                                                        <div class="col-lg-6">{{ form_row(form.showShowMoreToggleOnHomescreen) }}</div>
                                                        <div class="col-lg-6">{{ form_row(form.logoUrl) }}</div>
                                                        <div class="col-lg-6">{{ form_row(form.imageFile) }}</div>
                                                        <div class="col-lg-6">{{ form_row(form.logoStadtFile) }}</div>
                                                        <div class="col-md-4">{{ form_row(form.hauptfarbe) }}</div>
                                                        <div class="col-md-4">{{ form_row(form.akzentfarbe) }}</div>
                                                        <div class="col-md-4">{{ form_row(form.akzentfarbeFehler) }}</div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="tab-pane fade" id="module" role="tabpanel" aria-labelledby="tab-module-link">
                                                <div class="section-head">
                                                    <h2>Module</h2>
                                                    <p>Schalte Funktionen gezielt frei oder aus.</p>
                                                </div>
                                                <div class="config-card">
                                                    <div class="row g-4">
                                                        {% if form.active is defined %}
                                                            <div class="col-md-6">{{ form_row(form.active) }}</div>
                                                        {% endif %}
                                                        {% if form.onlineCheckinEnable %}
                                                            <div class="col-md-6">{{ form_row(form.onlineCheckinEnable) }}</div>
                                                        {% endif %}
                                                        {% if form.schulkindBetreung is defined %}
                                                            <div class="col-md-6">{{ form_row(form.schulkindBetreung) }}</div>
                                                        {% endif %}
                                                        {% if form.ferienprogramm is defined %}
                                                            <div class="col-md-6">{{ form_row(form.ferienprogramm) }}</div>
                                                        {% endif %}
                                                        {% if form.settingEncryptEmailAttachment is defined %}
                                                            <div class="col-md-6">{{ form_row(form.settingEncryptEmailAttachment) }}</div>
                                                        {% endif %}
                                                        {% if form.settingsSkibEnableParentSickDashboard is defined %}
                                                            <div class="col-md-6">{{ form_row(form.settingsSkibEnableParentSickDashboard) }}</div>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="tab-pane fade" id="texte" role="tabpanel" aria-labelledby="tab-texte-link">
                                                <div class="section-head">
                                                    <h2>Texte</h2>
                                                    <p>Pflege allgemeine Hinweise und Inhalte für die Oberfläche.</p>
                                                </div>
                                                <div class="config-card">
                                                    {{ a2lixTranslations.partialTranslations(form.translations, ['infoText']) }}
                                                </div>
                                            </div>

                                            <div class="tab-pane fade" id="rechtliches" role="tabpanel" aria-labelledby="tab-rechtliches-link">
                                                <div class="section-head">
                                                    <h2>Rechtliches</h2>
                                                    <p>Rechtlich relevante Inhalte an einer Stelle gebündelt.</p>
                                                </div>
                                                <div class="config-card mb-4">{{ form_row(form.imprint) }}</div>
                                                <div class="config-card">{{ a2lixTranslations.partialTranslations(form.translations, ['datenschutz']) }}</div>
                                            </div>

                                            <div class="tab-pane fade" id="schulkindbetreuung" role="tabpanel" aria-labelledby="tab-schulkindbetreuung-link">
                                                <div class="section-head">
                                                    <h2>Schulkindbetreuung</h2>
                                                    <p>Alle Regeln, Formulare und Sonderoptionen in logisch getrennten Blöcken.</p>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Sec-Code-Optionen</div>
                                                    <div class="row g-3">
                                                        <div class="col-md-6">{{ form_row(form.secCodeAlwaysNew) }}</div>
                                                        <div class="col-md-6">{{ form_row(form.noSecCodeForChangeChilds) }}</div>
                                                    </div>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Allgemein</div>
                                                    <div class="row g-3">
                                                        <div class="col-md-6">{{ form_row(form.minBlocksPerDay) }}</div>
                                                        <div class="col-md-6">{{ form_row(form.minDaysperWeek) }}</div>
                                                        <div class="col-md-6">{{ form_row(form.preiskategorien) }}</div>
                                                        <div class="col-md-6">{{ form_row(form.gehaltsklassen) }}</div>
                                                        <div class="col-12">{{ form_row(form.skibSettingsFinishButtonText) }}</div>
                                                    </div>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Upload-Optionen</div>
                                                    <div class="row g-3">
                                                        <div class="col-md-6">{{ form_row(form.settingsDokumentUploadEnable) }}</div>
                                                        <div class="col-md-6">{{ form_row(form.settingsDokumentUploadTitle) }}</div>
                                                        <div class="col-12">{{ form_row(form.settingsDokumentUploadText) }}</div>
                                                        <div class="col-12">{{ form_row(form.settingsDokumentTemplates) }}</div>
                                                    </div>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Stammdaten-Optionen</div>
                                                    <div class="mb-3">{{ form_row(form.hideChildQuestions) }}</div>

                                                    <div class="row g-3 align-items-start mb-3">
                                                        <div class="col-lg-4">{{ form_row(form.settingsAnzahlKindergeldempfanger) }}</div>
                                                        <div class="col-lg-4">{{ form_row(form.settingsAnzahlKindergeldempfangerRequired) }}</div>
                                                        <div class="col-lg-4">{{ a2lixTranslations.partialTranslations(form.translations, ['settingsAnzahlKindergeldempfangerHelp']) }}</div>
                                                    </div>

                                                    <div class="row g-3 align-items-start mb-3">
                                                        <div class="col-lg-4">{{ form_row(form.settingsSozielHilfeEmpfanger) }}</div>
                                                        <div class="col-lg-4">{{ form_row(form.settingsSozielHilfeEmpfangerRequired) }}</div>
                                                        <div class="col-lg-4">{{ a2lixTranslations.partialTranslations(form.translations, ['settingsSozielHilfeEmpfangerHelp']) }}</div>
                                                    </div>

                                                    <div class="row g-3 align-items-start mb-3">
                                                        <div class="col-lg-4">{{ form_row(form.settingKinderimKiga) }}</div>
                                                        <div class="col-lg-8">{{ a2lixTranslations.partialTranslations(form.translations, ['settingKinderimKigaHelp']) }}</div>
                                                    </div>



                                                    <div class="row g-3 align-items-start mb-3">
                                                        <div class="col-lg-4">{{ form_row(form.settingGehaltsklassen) }}</div>
                                                        <div class="col-lg-4">{{ form_row(form.settingGehaltsklassenRequired) }}</div>
                                                        <div class="col-lg-4">{{ a2lixTranslations.partialTranslations(form.translations, ['settingGehaltsklassenHelp']) }}</div>
                                                    </div>

                                                    <div class="row g-3 align-items-start mb-3">
                                                        <div class="col-lg-10">
                                                            {{ form_row(form.settingsweiterePersonenberechtigte) }}
                                                            {{ a2lixTranslations.partialTranslations(form.translations, ['settingsweiterePersonenberechtigteHelp']) }}
                                                        </div>
                                                    </div>

                                                    <div class="sub-card mt-4">
                                                        <div class="sub-card-title">Kinderfragen</div>
                                                        <div class="row g-3">
                                                            <div class="col-md-4">{{ form_widget(form.settingsSkibShowZeckenKinder) }}</div>
                                                            <div class="col-md-4">{{ form_widget(form.settingsSkibShowSonnencremeKinder) }}</div>
                                                            <div class="col-md-4">{{ form_widget(form.settingsSkibShowPflasterKinder) }}</div>
                                                            <div class="col-md-4">{{ form_widget(form.skipSettingShowChronicalDeseas) }}</div>

                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Geschwisterfragen</div>
                                                    <div class="row g-3">
                                                        <div class="col-lg-4">{{ form_row(form.settingsEingabeDerGeschwister) }}</div>
                                                        <div class="col-lg-4">{{ a2lixTranslations.partialTranslations(form.translations, ['settingsEingabeDerGeschwisterHelp']) }}</div>
                                                        <div class="col-lg-4">{{ a2lixTranslations.partialTranslations(form.translations, ['settingsEingabeDerGeschwisterHelpUpload']) }}</div>
                                                        <div class="col-12">{{ a2lixTranslations.partialTranslations(form.translations, ['schulkindbetreuungBlockDeaktiviertText']) }}</div>
                                                    </div>
                                                </div>

                                                <div class="row g-4">
                                                    <div class="col-xl-4">
                                                        <div class="config-card h-100">
                                                            <div class="card-title">SEPA-Optionen</div>
                                                            {{ form_row(form.settings_skib_sepaElektronisch) }}
                                                            {{ form_row(form.skibSettingsBypassBankdaten) }}
                                                            {{ form_row(form.allowCreateInvoiceInFuture) }}
                                                        </div>
                                                    </div>
                                                    <div class="col-xl-4">
                                                        <div class="config-card h-100">
                                                            <div class="card-title">Abschluss-Optionen</div>
                                                            {{ form_row(form.settingsSkibShowPopupOnRegistration) }}
                                                            {{ a2lixTranslations.partialTranslations(form.translations, ['settingsSkibPopupRegistrationText']) }}
                                                        </div>
                                                    </div>
                                                    <div class="col-xl-4">
                                                        <div class="config-card h-100">
                                                            <div class="card-title">Schuljahre</div>
                                                            {{ a2lixTranslations.partialTranslations(form.translations, ['settings_skib_shoolyear_naming']) }}
                                                        </div>
                                                    </div>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Extra-Texte in E-Mails</div>
                                                    <div class="row g-3">
                                                        <div class="col-lg-6">{{ a2lixTranslations.partialTranslations(form.translations, ['settingsExtraTextEmailAnmeldungMitBeworben']) }}</div>
                                                        <div class="col-lg-6">{{ a2lixTranslations.partialTranslations(form.translations, ['settingsExtraTextEmailAnmeldung']) }}</div>
                                                    </div>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Änderungen</div>
                                                    <div class="row g-3">
                                                        <div class="col-lg-4">{{ form_row(form.settingsSkibChangeDocumentChangeDateShow) }}</div>
                                                        <div class="col-lg-4">{{ form_row(form.settingSkibDefaultNextChange) }}</div>
                                                        <div class="col-lg-4">{{ form_row(form.settingsSkibShowSetStartDateOnChange) }}</div>
                                                        <div class="col-lg-6">{{ a2lixTranslations.partialTranslations(form.translations, ['settingsSkibTextWhenClosed']) }}</div>
                                                        <div class="col-lg-6">{{ a2lixTranslations.partialTranslations(form.translations, ['popUpTextVorBezahlung']) }}</div>
                                                    </div>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Abmeldung wenn Kinder nicht kopiert werden</div>
                                                    {{ form_row(form.skibSettingsAbmeldungEmailText) }}
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Dokumente für E-Mail-Anhänge</div>
                                                    <div class="row g-3">
                                                        <div class="col-lg-4">{{ form_row(form.settings_skib_disableIcs) }}</div>
                                                        <div class="col-lg-3">{{ form_row(form.emailDokumente_schulkindbetreuung_anmeldung) }}</div>
                                                        <div class="col-lg-3">{{ form_row(form.emailDokumente_schulkindbetreuung_buchung) }}</div>
                                                        <div class="col-lg-3">{{ form_row(form.emailDokumente_schulkindbetreuung_anderung) }}</div>
                                                        <div class="col-lg-3">{{ form_row(form.emailDokumente_schulkindbetreuung_abmeldung) }}</div>
                                                    </div>
                                                </div>

                                                <div class="config-card">
                                                    {{ a2lixTranslations.partialTranslations(form.translations, ['agb','catererInfo','careBlockInfo','schulindbetreuungPreiseFreitext']) }}
                                                </div>
                                            </div>

                                            <div class="tab-pane fade" id="ferienbetreeuung" role="tabpanel" aria-labelledby="tab-ferienbetreeuung-link">
                                                <div class="section-head">
                                                    <h2>Ferienbetreuung</h2>
                                                    <p>Der Bereich ist vorbereitet und kann im gleichen Stil erweitert werden.</p>
                                                </div>
                                                <div class="config-card empty-state">
                                                    <div class="empty-state-icon">☀️</div>
                                                    <h3>Noch keine Inhalte</h3>
                                                    <p>Hier können später spezielle Einstellungen für die Ferienbetreuung ergänzt werden.</p>
                                                </div>
                                            </div>

                                            <div class="tab-pane fade" id="emails" role="tabpanel" aria-labelledby="tab-emails-link">
                                                <div class="section-head">
                                                    <h2>E-Mails</h2>
                                                    <p>Templates zentral pflegen und direkt testen.</p>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Anmeldebestätigung beworben</div>
                                                    {{ a2lixTranslations.partialTranslations(form.translations, ['emailtemplateAnmeldung']) }}
                                                    <a class="btn btn-outline-primary btn-sm mt-3" href="{{ path('app_send_test_email_for_template',{'template':'anmeldebestatigungBeworben','stadt':stadt.id}) }}" target="_blank">Testmail senden</a>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Buchungsbestätigung</div>
                                                    {{ a2lixTranslations.partialTranslations(form.translations, ['emailtemplateBuchung']) }}
                                                    <a class="btn btn-outline-primary btn-sm mt-3" href="{{ path('app_send_test_email_for_template',{'template':'anmeldebestatigung','stadt':stadt.id}) }}" target="_blank">Testmail senden</a>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Abmeldebestätigung</div>
                                                    {{ a2lixTranslations.partialTranslations(form.translations, ['emailtemplateAbmeldung']) }}
                                                    <a class="btn btn-outline-primary btn-sm mt-3" href="{{ path('app_send_test_email_for_template',{'template':'abmeldebestatigung','stadt':stadt.id}) }}" target="_blank">Testmail senden</a>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Stammdaten bearbeiten</div>
                                                    {{ a2lixTranslations.partialTranslations(form.translations, ['emailtemplateStammdatenEdit']) }}
                                                    <a class="btn btn-outline-primary btn-sm mt-3" href="{{ path('app_send_test_email_for_template',{'template':'stammdatenEdit','stadt':stadt.id}) }}" target="_blank">Testmail senden</a>
                                                </div>

                                                <div class="config-card">
                                                    <div class="card-title">Verfügbare Variablen</div>
                                                    <div class="row g-4">
                                                        <div class="col-lg-6">
                                                            <div class="variable-box">
                                                                <div class="variable-title">eltern</div>
                                                                <ul class="variable-list">
                                                                    <li><code>.vorname</code> Vorname</li>
                                                                    <li><code>.name</code> Nachname</li>
                                                                    <li><code>.strasse</code> Straße</li>
                                                                    <li><code>.adresszusatz</code> Adresszusatz</li>
                                                                    <li><code>.plz</code> Postleitzahl</li>
                                                                    <li><code>.stadt</code> Stadt</li>
                                                                    <li><code>.email</code> E-Mail-Adresse</li>
                                                                    <li><code>.phoneNumber</code> Telefonnummer</li>
                                                                    <li><code>.secCode</code> Security Code</li>
                                                                </ul>
                                                            </div>
                                                        </div>
                                                        <div class="col-lg-6">
                                                            <div class="variable-box">
                                                                <div class="variable-title">kind</div>
                                                                <ul class="variable-list">
                                                                    <li><code>.vorname</code> Vorname</li>
                                                                    <li><code>.nachname</code> Nachname</li>
                                                                    <li><code>.geburtstag</code> Geburtsdatum</li>
                                                                    <li><code>.eltern</code> Verknüpfte Eltern-Entität</li>
                                                                    <li><code>.zeitblocks</code> Zugewiesene Zeitblöcke</li>
                                                                    <li><code>.beworben</code> Beworbene Zeitblöcke</li>
                                                                </ul>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="tab-pane fade" id="auto-assign" role="tabpanel" aria-labelledby="tab-auto-assign">
                                                <div class="section-head">
                                                    <h2>Automatische Blockzuteilung</h2>
                                                    <p>Definiere die Gewichtungsformel für die automatische Zuweisung von Betreuungsblöcken.</p>
                                                </div>

