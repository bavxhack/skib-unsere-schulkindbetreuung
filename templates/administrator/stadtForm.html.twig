                                                        </div>
                                                    </li>
                                                {% endfor %}
                                            </ul>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}



{% block jquery %}
    <script>
        $(document).ready(function () {
            var form = $('#city-config-form'),
                original = form.serialize();

            form.on('submit', function () {
                window.onbeforeunload = null;
            });

            window.onbeforeunload = function () {
                if (form.serialize() !== original) {
                    return 'Ungespeicherte Änderungen gehen verloren. Wirklich verlassen?';
                }
            };

            $('#city-config-tabs a[data-toggle="tab"]').on('shown.bs.tab', function (e) {
                try {
                    localStorage.setItem('cityConfigActiveTab', $(e.target).attr('href'));
                } catch (err) {}
            });

            try {
                var activeTab = localStorage.getItem('cityConfigActiveTab');
                if (activeTab && $('#city-config-tabs a[href="' + activeTab + '"]').length) {
                    $('#city-config-tabs a[href="' + activeTab + '"]').tab('show');
                }
            } catch (err) {}

            // auto assign formula test
            const calculateTestValue = async function () {
                const formula = $('#stadt_autoAssign_formula').val();
                const response = await fetch('{{ path('admin_formula_test') }}', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                        },
                        body: JSON.stringify({formula: formula})
                    }
                );

                const resultInput = $('#auto_assign_formula-result');
                if (!response.ok) {
                    resultInput.val('Fehler')
                    return;
                }
                const data = await response.json();
                resultInput.val(data.weight)
            };
            $('#stadt_autoAssign_formula').on('change', calculateTestValue);
            calculateTestValue();
        });
    </script>
{% endblock %}
