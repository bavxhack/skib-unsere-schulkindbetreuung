{% extends 'adminBase.html.twig' %}

{% block content %}
    <section class="dashboard-counts section-padding">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12 card">
                    <div class="card-header">
                        <h1>{% trans %}Schuljahr mit Kindern löschen{% endtrans %}</h1>
                        <p class="mb-0">
                            {% trans %}Schuljahr{% endtrans %}: {{ activity.von|date('d.m.Y') }} - {{ activity.bis|date('d.m.Y') }}
                        </p>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-danger" role="alert">
                            {% trans %}Achtung: Diese Aktion löscht das Schuljahr, alle zugeordneten Kinder (Abmeldung) und alle Zeitblöcke dieses Schuljahres.{% endtrans %}
                        </div>

                        <h3>{% trans %}Kinder, die betroffen sind{% endtrans %} ({{ kinder|length }})</h3>
                        {% if kinder|length > 0 %}
                            <ul class="list-group mb-3">
                                {% for kind in kinder %}
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span>{{ kind.vorname }} {{ kind.nachname }}</span>
                                        <small>{{ kind.schule ? kind.schule.name : '-' }}</small>
                                    </li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <p>{% trans %}Es wurden keine Kinder für dieses Schuljahr gefunden.{% endtrans %}</p>
                        {% endif %}

                        <form method="post" action="{{ path('city_admin_schuljahr_delete_with_children', {'id': activity.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_schuljahr_with_children_' ~ activity.id) }}">
                            <a class="btn btn-secondary" href="{{ path('city_admin_schuljahr_anzeige',{'id':activity.stadt.id}) }}">{% trans %}Abbrechen{% endtrans %}</a>
                            <button type="submit" class="btn btn-danger"
                                    onclick="return confirm('{{ 'Möchten Sie dieses Schuljahr und alle oben gelisteten Daten wirklich löschen?'|trans }}')">
                                {% trans %}Endgültig löschen{% endtrans %}
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}
